local Settings = {
    Enabled = true,
    MoveSpeed = 20,
    StepDistance = 12, -- 每段距离（关键）
    ScanDelay = 1
}

local CurrentTarget = nil
local IsMoving = false

local function GetHRP()
    return game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
end

-- 🔍 扫描目标
local function GetTargets()
    local list = {}

    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") then
            local name = string.lower(v.Name)
            if string.find(name, "safe") or string.find(name, "register") then
                table.insert(list, v)
            end
        end
    end

    return list
end

-- 📏 找最近
local function GetClosest(list)
    local hrp = GetHRP()
    if not hrp then return nil end

    local closest, dist = nil, math.huge

    for _, v in ipairs(list) do
        if v and v.Parent then
            local d = (v.Position - hrp.Position).Magnitude
            if d < dist then
                dist = d
                closest = v
            end
        end
    end

    return closest
end

-- 🧠 分段移动（核心）
local function MoveTo(pos)
    local hrp = GetHRP()
    if not hrp then return end

    IsMoving = true

    while Settings.Enabled do
        local currentPos = hrp.Position
        local direction = (pos - currentPos)
        local dist = direction.Magnitude

        if dist < 2 then break end -- 到了

        -- 每次只走一小段
        local step = math.min(Settings.StepDistance, dist)
        local nextPos = currentPos + direction.Unit * step

        local tween = game:GetService("TweenService"):Create(
            hrp,
            TweenInfo.new(step / Settings.MoveSpeed, Enum.EasingStyle.Linear),
            {CFrame = CFrame.new(nextPos + Vector3.new(0, 3, 0))}
        )

        tween:Play()
        tween.Completed:Wait()

        -- 👉 每段移动后可被打断
        if not CurrentTarget then break end
    end

    IsMoving = false
end

-- 🔁 主循环
task.spawn(function()
    while Settings.Enabled do
        task.wait(Settings.ScanDelay)

        if not IsMoving then
            local targets = GetTargets()
            local closest = GetClosest(targets)

            if closest then
                CurrentTarget = closest
                MoveTo(closest.Position)
            end
        end
    end
end)

-- ⚠️ 被抢检测（分段版更灵敏）
task.spawn(function()
    while true do
        task.wait(0.15)

        if CurrentTarget and IsMoving then
            local p = CurrentTarget.Parent
            if p and p:FindFirstChild("Values") then
                local v = p.Values
                local taken =
                    (v:FindFirstChild("Broken") and v.Broken.Value) or
                    (v:FindFirstChild("Open") and v.Open.Value)

                if taken then
                    print("⚠️ 被抢，中断分段移动")
                    CurrentTarget = nil
                end
            end
        end
    end
end)

print("✅ 分段坐标版已启动")
