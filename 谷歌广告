-- [[ Zenith Hub: Criminality 高质量自创版 - 第一部分 ]]
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local VIM = game:GetService("VirtualInputManager")
local LocalPlayer = Players.LocalPlayer

-- 初始化设置表 (质量优先：集中管理)
_G.ZenithSettings = {
    Enabled = false,
    Speed = 22,
    AutoRespawn = true,
    DealerWait = 5,
    PickupDistance = 8,
    CurrentTarget = nil,
    Status = "等待启动"
}

-- [高质量优化：网络与性能]
settings().Network.IncomingReplicationLag = 0
if setfpscap then setfpscap(120) end

local function OptimizePerformance(char)
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanTouch = false
            part.CastShadow = false
        end
    end
end

-- [基础功能：工具检测]
local function HasCrowbar()
    local char = LocalPlayer.Character
    local backpack = LocalPlayer.Backpack
    return (char and char:FindFirstChild("Crowbar")) or (backpack and backpack:FindFirstChild("Crowbar"))
end

-- [基础功能：死亡复活]
local function ConnectCharacter(char)
    local humanoid = char:WaitForChild("Humanoid")
    humanoid.Died:Connect(function()
        if _G.ZenithSettings.AutoRespawn then
            _G.ZenithSettings.Status = "死亡复活中..."
            task.wait(2.5) -- 等待复活面板出现
            VIM:SendKeyEvent(true, Enum.KeyCode.E, false, game)
            task.wait(0.1)
            VIM:SendKeyEvent(false, Enum.KeyCode.E, false, game)
        end
    end)
    OptimizePerformance(char)
end

if LocalPlayer.Character then ConnectCharacter(LocalPlayer.Character) end
LocalPlayer.CharacterAdded:Connect(ConnectCharacter)
-- [[ Zenith Hub: 核心逻辑层 - 第二部分 ]]

-- 寻找黑商 NPC
local function GetDealer()
    for _, v in ipairs(Workspace:GetDescendants()) do
        if v.Name == "Dealer" or v:FindFirstChild("DealerPrompt") then
            local root = v:IsA("BasePart") and v or v:FindFirstChildWhichIsA("BasePart", true)
            if root then return root end
        end
    end
    return nil
end

-- 扫描最近的收银机或保险箱
local function GetNearestTarget()
    local nearest = nil
    local minDist = math.huge
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end

    -- 假设目标在 Workspace.Filter 或特定目录下，根据 Criminality 实际结构调整
    local targets = Workspace:FindFirstChild("Filter") or Workspace
    for _, obj in ipairs(targets:GetDescendants()) do
        if obj.Name == "Register" or obj.Name == "Safe" then
            -- 质量检查：必须是没被开过的 (根据游戏属性微调)
            local isOpen = obj:FindFirstChild("Open") and obj.Open.Value == true
            if not isOpen then
                local d = (hrp.Position - obj.Position).Magnitude
                if d < minDist then
                    minDist = d
                    nearest = obj
                end
            end
        end
    end
    return nearest
end

-- 核心移动函数 (带中断检测)
local function MoveTo(target, isDealer)
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp or not target then return end

    _G.ZenithSettings.CurrentTarget = target
    local connection
    local arrived = false

    connection = RunService.Heartbeat:Connect(function(dt)
        if not _G.ZenithSettings.Enabled and not isDealer then 
            connection:Disconnect() 
            return 
        end
        
        -- 【中断检查】：如果目标是保险箱且被开了，立即中断
        if not isDealer and target.Name == "Safe" then
            if target:FindFirstChild("Open") and target.Open.Value == true then
                _G.ZenithSettings.Status = "目标已失效，重新规划"
                connection:Disconnect()
                arrived = false -- 触发重新寻找
                return
            end
        end

        local dist = (target.Position - hrp.Position).Magnitude
        if dist < 4 then
            arrived = true
            connection:Disconnect()
            return
        end

        -- 平移逻辑 (0-30 速度)
        local dir = (target.Position - hrp.Position).Unit
        hrp.CFrame = hrp.CFrame + (dir * _G.ZenithSettings.Speed * dt)
    end)

    repeat task.wait() until arrived or not _G.ZenithSettings.Enabled
    return arrived
end
-- [[ Zenith Hub: 主循环与极简 UI - 第三部分 ]]

-- 自动任务主循环
task.spawn(function()
    while true do
        task.wait(0.5)
        if _G.ZenithSettings.Enabled then
            -- 1. 检查工具
            if not HasCrowbar() then
                _G.ZenithSettings.Status = "缺少工具，前往黑商"
                local dealer = GetDealer()
                if dealer then
                    if MoveTo(dealer, true) then
                        VIM:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                        task.wait(0.1)
                        VIM:SendKeyEvent(false, Enum.KeyCode.E, false, game)
                        _G.ZenithSettings.Status = "补给完成，冷却5秒"
                        task.wait(_G.ZenithSettings.DealerWait)
                    end
                end
            else
                -- 2. 正常刷钱
                local target = GetNearestTarget()
                if target then
                    _G.ZenithSettings.Status = "前往: " .. target.Name
                    MoveTo(target, false)
                else
                    _G.ZenithSettings.Status = "扫描中..."
                end
            end
        end
    end
end)

