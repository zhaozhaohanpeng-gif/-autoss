-- [[ 隐身与角色状态逻辑 ]]
do
    repeat task.wait() until game:IsLoaded()
    local character, humanoid, hrp
    local function updateChar()
        character = LocalPlayer.Character
        if character then
            hrp = character:FindFirstChild("HumanoidRootPart")
            humanoid = character:FindFirstChildOfClass("Humanoid")
        end
    end
    updateChar()

    local InvisPossible = true
    local InvisActive = false
    local InvisAnim = Instance.new("Animation")
    InvisAnim.AnimationId = "rbxassetid://215384594"
    local InvisAnimTrack = nil

    local function loadInvisAnim()
        if InvisAnimTrack then pcall(function() InvisAnimTrack:Stop() end) end
        if humanoid then
            local success, track = pcall(function() return humanoid:LoadAnimation(InvisAnim) end)
            if success then InvisAnimTrack = track; InvisAnimTrack.Priority = Enum.AnimationPriority.Action4 end
        end
    end

    -- 隐身核心循环
    RunService.Heartbeat:Connect(function(dt)
        if not InvisActive or not character or not hrp or humanoid.Health <= 0 then return end
        
        local speed = 12
        if humanoid.MoveDirection.Magnitude > 0 then
            hrp.CFrame = hrp.CFrame + (humanoid.MoveDirection * speed * dt)
        end

        local originalCF = hrp.CFrame
        local _, cameraYaw = workspace.CurrentCamera.CFrame:ToOrientation()
        hrp.CFrame = CFrame.new(hrp.Position) * CFrame.fromOrientation(0, cameraYaw, 0) * CFrame.Angles(math.rad(90), 0, 0)
        
        RunService.RenderStepped:Wait()
        hrp.CFrame = originalCF
        
        for _, part in pairs(character:GetDescendants()) do
            if part:IsA("BasePart") and part.Transparency ~= 1 then part.Transparency = 0.5 end
        end
    end)

    _G.Invis_Toggle = function()
        InvisActive = not InvisActive
        if InvisActive then loadInvisAnim() else 
            for _, part in pairs(character:GetDescendants()) do
                if part:IsA("BasePart") then part.Transparency = 0 end
            end
        end
        return InvisActive
    end
end

-- 高度上升逻辑 (防止卡地壳)
local function RiseToTargetY()
    if HasReachedTargetY or IsRising then return end
    local character = LocalPlayer.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if hrp and hrp.Position.Y < 4.7 then
        IsRising = true
        StatusText = "正在校准高度..."
        local targetCF = CFrame.new(hrp.Position.X, 4.8, hrp.Position.Z) * (hrp.CFrame - hrp.CFrame.Position)
        local tween = TweenService:Create(hrp, TweenInfo.new(0.5), {CFrame = targetCF})
        tween:Play()
        tween.Completed:Wait()
        task.wait(2)
        IsRising = false
        HasReachedTargetY = true
    end
end

-- 禁用地图门的碰撞
local function DisableDoorsCollision()
    local map = Workspace:FindFirstChild("Map")
    if map and map:FindFirstChild("Doors") then
        for _, door in ipairs(map.Doors:GetDescendants()) do
            if door:IsA("BasePart") then door.CanCollide = false end
        end
    end
end
DisableDoorsCollision()
-- [[ 寻路与主逻辑 ]]
local function ComputePath(startPos, endPos)
    local params = {AgentRadius = 1.5, AgentHeight = 5, AgentCanJump = true, WaypointSpacing = 3}
    local path = PathfindingService:CreatePath(params)
    local success, _ = pcall(function() path:ComputeAsync(startPos, endPos) end)
    if success and path.Status == Enum.PathStatus.Success then return path:GetWaypoints() end
    return nil
end

